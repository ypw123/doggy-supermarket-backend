generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PromotionStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  phone        String?    @unique
  passwordHash String?
  nameEn       String
  nameZh       String
  avatar       String     @default("莓")
  tierEn       String     @default("Berry Friend")
  tierZh       String     @default("莓果会员")
  memberNo     String     @unique
  points       Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  addresses    Address[]
  carts        Cart[]
  orders       Order[]
  pointLogs    PointLog[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String   @default("default")
  receiver    String?
  phone       String?
  province    String?
  city        String?
  district    String?
  line1       String
  line2       String?
  isDefault   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id        String    @id @default(cuid())
  code      String    @unique
  nameEn    String
  nameZh    String
  icon      String?
  sortOrder Int       @default(0)
  products  Product[]
}

model Product {
  id          String        @id @default(cuid())
  code        String        @unique
  sku         String        @unique
  categoryId  String
  nameEn      String
  nameZh      String
  detailEn    String
  detailZh    String
  altEn       String
  altZh       String
  tagEn       String?
  tagZh       String?
  imageUrl    String
  priceCents  Int
  currency    String        @default("USD")
  stock       Int           @default(0)
  status      ProductStatus @default(ACTIVE)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    Category      @relation(fields: [categoryId], references: [id])
  cartItems   CartItem[]
  orderItems  OrderItem[]
  bundleItems BundleItem[]

  @@index([categoryId, status])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  status    String     @default("ACTIVE")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([userId, status])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String
  status          OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentProvider String?
  paymentIntentId String?
  subtotalCents   Int
  shippingCents   Int           @default(0)
  discountCents   Int           @default(0)
  totalCents      Int
  currency        String        @default("USD")
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  productCode    String
  productNameEn  String
  productNameZh  String
  imageUrl       String
  unitPriceCents Int
  quantity       Int
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])
}

model Bundle {
  id          String       @id @default(cuid())
  code        String       @unique
  titleEn     String
  titleZh     String
  textEn      String
  textZh      String
  ctaEn       String
  ctaZh       String
  statusEn    String
  statusZh    String
  priceCents  Int
  currency    String       @default("USD")
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  items       BundleItem[]
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  quantity  Int     @default(1)
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([bundleId, productId])
}

model Promotion {
  id             String          @id @default(cuid())
  code           String          @unique
  titleEn        String
  titleZh        String
  descriptionEn  String
  descriptionZh  String
  discountType   String
  discountValue  Int
  status         PromotionStatus @default(ACTIVE)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime        @default(now())
}

model RecentPurchase {
  id            String   @id @default(cuid())
  buyerEn       String
  buyerZh       String
  cityEn        String
  cityZh        String
  productNameEn String
  productNameZh String
  quantity      Int      @default(1)
  purchasedAt   DateTime @default(now())
}

model PointLog {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  reasonEn    String
  reasonZh    String
  source      String
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
